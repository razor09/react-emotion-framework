{
  "scripts": {
    "mocks:dev": "npm run serve:dev -- --name mocks",
    "mocks:prod": "npm run serve:prod -- --name mocks",
    "serve:dev": "npm run serve -- --mode development",
    "serve:prod": "npm run serve -- --mode production",
    "serve": "webpack serve --config $npm_package_config_webpack",
    "build": "webpack --config $npm_package_config_webpack --mode production",
    "generate": "ts-node tools/codegen/generate.ts",
    "lint": "prettier --write .",
    "fetch": "rm -rf node_modules && npm ci",
    "update": "ncu -u && rm -rf node_modules package-lock.json && npm i"
  },
  "config": {
    "webpack": "webpack/config.ts"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run build && npm run lint && git add --all"
  },
  "prettier": {
    "printWidth": 150,
    "semi": false,
    "singleQuote": true,
    "singleAttributePerLine": true
  },
  "dependencies": {
    "mobx": "6.16.1",
    "mobx-react-lite": "4.1.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.17.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@emotion/babel-plugin": "11.13.5",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@faker-js/faker": "10.4.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "babel-loader": "10.1.1",
    "html-webpack-plugin": "5.6.7",
    "msw": "2.14.6",
    "npm-check-updates": "22.2.3",
    "prettier": "3.8.4",
    "simple-git-hooks": "2.13.1",
    "terser-webpack-plugin": "5.6.1",
    "ts-loader": "9.6.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3",
    "webpack-dev-server": "5.2.5"
  }
}
